# Supabase (Optional - remove if not using backend)
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# Set to true in development to skip email confirmation (users can log in immediately)
# Set to false in production (configure SMTP in Supabase dashboard)
SKIP_EMAIL_CONFIRMATION=false

# Webhook shared secret — used to authenticate incoming webhook calls before Stripe is connected
# Generate with: openssl rand -hex 32
WEBHOOK_SECRET=your_webhook_secret_here

# Email notifications (PROJ-14) — Gmail SMTP
# SMTP_USER: your Gmail address
# SMTP_PASS: Gmail App Password (16-char, from https://myaccount.google.com/apppasswords)
SMTP_USER=onslide.studio@gmail.com
SMTP_PASS=your_app_password_here
NEXT_PUBLIC_APP_URL=https://your-app-url.com

# ConvertAPI — PPTX → PNG thumbnail generation
# Get your secret at https://www.convertapi.com/a
CONVERTAPI_SECRET=your_convertapi_secret_here

# Beta access gate — set a password to require visitors to enter it before using the app.
# Leave empty or remove to disable the gate (e.g. for local development).
# BETA_ACCESS_PASSWORD=your_beta_password_here

# Add more environment variables as needed
# STRIPE_SECRET_KEY=sk_...
